slider22:180<-360,360,0.1>S5 azimuth (deg)
slider23:0<-90,90,0.1>S5 elevation (deg)
slider24:1<0.1,3,0.01>S5 distance (radius, edge=1)
slider25:-135<-360,360,0.1>S6 azimuth (deg)
slider26:0<-90,90,0.1>S6 elevation (deg)
slider27:1<0.1,3,0.01>S6 distance (radius, edge=1)
slider28:-90<-360,360,0.1>S7 azimuth (deg)
slider29:0<-90,90,0.1>S7 elevation (deg)
slider30:1<0.1,3,0.01>S7 distance (radius, edge=1)
slider31:-45<-360,360,0.1>S8 azimuth (deg)
slider32:0<-90,90,0.1>S8 elevation (deg)
slider33:1<0.1,3,0.01>S8 distance (radius, edge=1)

slider34:0<-60,24,0.1>S1 gain (dB)
slider35:0<0,1,1>S1 mute
slider36:0<0,1,1>S1 solo
slider37:0<-60,24,0.1>S2 gain (dB)
slider38:0<0,1,1>S2 mute
slider39:0<0,1,1>S2 solo
slider40:0<-60,24,0.1>S3 gain (dB)
slider41:0<0,1,1>S3 mute
slider42:0<0,1,1>S3 solo
