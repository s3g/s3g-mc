@sample
i = 0;
loop(NUM_SPEAKERS,
  mix[i] = 0;
  i += 1;
);

solo_count = 0;
src = 0;
loop(NUM_SOURCES,
  src_solo[src] ? solo_count += 1;
  src += 1;
);

src = 0;
loop(NUM_SOURCES,
  active_source = src < num_ch && !src_mute[src] && (solo_count == 0 || src_solo[src]);
  active_source ? (
    input = spl(src);

    idx_a = src;
    idx_b = 8 + src;
    idx_c = 16 + src;
    idx_d = 24 + src;

    az_ab = lerp_degrees(scene_az[idx_a], scene_az[idx_b], morph_x);
    az_cd = lerp_degrees(scene_az[idx_c], scene_az[idx_d], morph_x);
    source_az = lerp_degrees(az_ab, az_cd, morph_y) + global_az;

    el_ab = lerp(scene_el[idx_a], scene_el[idx_b], morph_x);
    el_cd = lerp(scene_el[idx_c], scene_el[idx_d], morph_x);
    source_el = max(0, min(90, lerp(el_ab, el_cd, morph_y) + global_el));

    dist_ab = lerp(scene_dist[idx_a], scene_dist[idx_b], morph_x);
    dist_cd = lerp(scene_dist[idx_c], scene_dist[idx_d], morph_x);
    source_dist_target = clamp_distance(lerp(dist_ab, dist_cd, morph_y) + global_dist);
    dist_z[src] = source_dist_target + (dist_z[src] - source_dist_target) * distance_coef;
    source_dist = dist_z[src];
    source_radius = clamp_distance(source_dist);
    source_amp = distance_amp(source_dist);
    wrapped_az = wrap_degrees(source_az);

    w1 = 0; w2 = 0; w3 = 0; w4 = 0;
    source_el <= 32 ? (
      layer_t = source_el / 32;
      w1 = cos(layer_t * $pi / 2);
      w2 = sin(layer_t * $pi / 2);
    ) : source_el <= 66.6 ? (
      layer_t = (source_el - 32) / (66.6 - 32);
      w2 = cos(layer_t * $pi / 2);
      w3 = sin(layer_t * $pi / 2);
    ) : (
      layer_t = (source_el - 66.6) / (90 - 66.6);
      w3 = cos(layer_t * $pi / 2);
      w4 = sin(layer_t * $pi / 2);
    );

    scale = 0;
    spk = 0;
    loop(NUM_SPEAKERS,
      g = source_gain(spk_az[spk], spk_step[spk], spk_layer[spk], wrapped_az, source_radius, w1, w2, w3, w4);
      src_gain[spk] = g;
      scale += g * g;
      spk += 1;
    );

    scale = scale < EPS ? 1 : sqrt(scale);
    weighted = input * src_level[src] * source_amp;
    spk = 0;
    loop(NUM_SPEAKERS,
      target_gain = src_gain[spk] / scale;
      gain_index = src * NUM_SPEAKERS + spk;
      smooth_gain[gain_index] = target_gain + (smooth_gain[gain_index] - target_gain) * gain_coef;
      mix[spk] += weighted * smooth_gain[gain_index];
      spk += 1;
    );
  );

  src += 1;
);

i = 0;
loop(NUM_SPEAKERS,
  spl(i) = mix[i] * out_gain;
  i += 1;
);

i = NUM_SPEAKERS;
loop(64 - NUM_SPEAKERS,
  spl(i) = 0;
  i += 1;
);
