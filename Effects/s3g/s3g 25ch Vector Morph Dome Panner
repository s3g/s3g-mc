function wrap_degrees(deg) local(wrapped)
(
  wrapped = deg - floor(deg / 360) * 360;
  wrapped > 180 ? wrapped -= 360;
  wrapped;
);

function lerp(a, b, t)
(
  a + (b - a) * t;
);

function lerp_degrees(a, b, t) local(diff)
(
  diff = wrap_degrees(b - a);
  wrap_degrees(a + diff * t);
);

function abs_degrees(deg)
(
  deg < 0 ? -deg : deg;
);

function clamp_distance(distance)
(
  distance < 0.1 ? 0.1 : distance;
);

function distance_amp(distance)
(
  distance <= 1 ? 1 :
  distance_rolloff_db == 6 ? 1 / distance :
  distance_rolloff_db == 12 ? 1 / (distance * distance) :
  distance_rolloff_db == 18 ? 1 / (distance * distance * distance) :
  1 / (distance ^ (distance_rolloff_db / 6));
);

function lbap_ring_gain(source_az, speaker_az, step_degrees, layer_gain) local(diff, v)
(
  layer_gain <= EPS ? (
    0;
  ) : (
    diff = abs_degrees(wrap_degrees(source_az - speaker_az));
    diff > step_degrees ? (
      0;
    ) : (
      v = cos(diff / step_degrees * $pi / 2);
      lbap_sharpness == 1 ? layer_gain * v :
      lbap_sharpness == 2 ? layer_gain * v * v :
      layer_gain * (v ^ lbap_sharpness);
    );
  );
);

function source_gain(speaker_az, step_degrees, layer_index, wrapped_az, radius, w1, w2, w3, w4) local(directional)
(
  directional = w4;
  layer_index == 1 ? directional = lbap_ring_gain(wrapped_az, speaker_az, step_degrees, w1);
  layer_index == 2 ? directional = lbap_ring_gain(wrapped_az, speaker_az, step_degrees, w2);
  layer_index == 3 ? directional = lbap_ring_gain(wrapped_az, speaker_az, step_degrees, w3);
  radius < 1 ? (1 - radius + directional * radius) : directional;
);

