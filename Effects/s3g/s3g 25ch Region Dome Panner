function triangle_gain(spk_id, pos, depth, width, a, b, c) local(wa, wb, wc, center, perimeter)
(
  center = min(max(depth, 0), 1);
  perimeter = path4_gain(spk_id, pos, width, 1, a, b, c, a);
  wa = spk_id == a ? 1/3 : 0;
  wb = spk_id == b ? 1/3 : 0;
  wc = spk_id == c ? 1/3 : 0;
  perimeter * (1 - center) + (wa + wb + wc) * center;
);

function constellation_selected(src, speaker_index) local(mask, div)
(
  mask = max(0, floor(constel_bits[src] + 0.5));
  div = 2 ^ speaker_index;
  floor(mask / div) - floor(mask / (div * 2)) * 2;
);

function constellation_gain(src, spk_id, pos, width) local(i, count, rank, selected, closed, target_pos, denom)
(
  count = 0;
  rank = -1;
  i = 0;
  loop(NUM_SPEAKERS,
    selected = constellation_selected(src, i) >= 0.5;
    selected ? (
      spk_id == i + 1 ? rank = count;
      count += 1;
    );
    i += 1;
  );

  count <= 0 ? (
    0;
  ) : count == 1 ? (
    rank == 0 ? 1 : 0;
  ) : rank < 0 ? (
    0;
  ) : (
    closed = constel_closed[src] >= 0.5;
    denom = closed ? count : count - 1;
    target_pos = rank / denom;
    node_gain(spk_id, spk_id, target_pos, pos, width, closed);
  );
);

function region_gain(src, shape, spk_id, pos, depth, width)
(
  shape == 0 ? path12_gain(spk_id, pos, width, 1) :
  shape == 1 ? path8_gain(spk_id, pos, width, 1, 13, 14, 15, 16, 17, 18, 19, 20) :
  shape == 2 ? path4_gain(spk_id, pos, width, 1, 21, 22, 23, 24) :
  shape == 3 ? path7_gain(spk_id, pos, width, 0, 9, 18, 23, 25, 21, 14, 3) :
  shape == 4 ? path4_open_gain(spk_id, pos, width, 12, 20, 24, 25) :
  shape == 5 ? path4_open_gain(spk_id, pos, width, 9, 18, 23, 25) :
  shape == 6 ? triangle_gain(spk_id, pos, depth, width, 10, 19, 11) :
  shape == 7 ? path5_gain(spk_id, pos, width, 1, 21, 22, 23, 24, 25) :
  shape == 8 ? path7_gain(spk_id, pos, width, 0, 12, 20, 24, 25, 22, 16, 6) :
  shape == 9 ? triangle_gain(spk_id, pos, depth, width, 1, 13, 2) :
  shape == 10 ? triangle_gain(spk_id, pos, depth, width, 4, 15, 5) :
  shape == 11 ? triangle_gain(spk_id, pos, depth, width, 7, 17, 8) :
  shape == 12 ? spiral25_gain(spk_id, pos, width) :
  constellation_gain(src, spk_id, pos, width);
);

