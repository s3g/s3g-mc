  node_gain(spk_id, h, 6/8, pos, width, closed) +
  node_gain(spk_id, j, 7/8, pos, width, closed);
);

function path12_gain(spk_id, pos, width, closed)
(
  node_gain(spk_id, 1, 0/12, pos, width, closed) +
  node_gain(spk_id, 2, 1/12, pos, width, closed) +
  node_gain(spk_id, 3, 2/12, pos, width, closed) +
