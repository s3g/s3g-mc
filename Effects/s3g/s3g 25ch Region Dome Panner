function wrap_degrees(deg) local(wrapped)
(
  wrapped = deg - floor(deg / 360) * 360;
  wrapped > 180 ? wrapped -= 360;
  wrapped;
);

function abs_degrees(deg)
(
  deg < 0 ? -deg : deg;
);

function clamp_distance(distance)
(
  distance < 0.1 ? 0.1 : distance;
);

function distance_amp(distance)
(
  distance <= 1 ? 1 :
  distance_rolloff_db == 6 ? 1 / distance :
  distance_rolloff_db == 12 ? 1 / (distance * distance) :
  distance_rolloff_db == 18 ? 1 / (distance * distance * distance) :
  1 / (distance ^ (distance_rolloff_db / 6));
);

function node_gain(spk_id, target_id, node_position, pos, width, closed) local(d, spread)
(
  spk_id == target_id ? (
    d = abs(pos - node_position);
    closed ? d = min(d, 1 - d);
    spread = 0.001 + width * 0.30;
    d > spread ? 0 : cos(d / spread * $pi / 2) ^ region_sharpness;
  ) : (
    0;
  );
);

function path4_gain(spk_id, pos, width, closed, a, b, c, d)
(
  node_gain(spk_id, a, 0/4, pos, width, closed) +
  node_gain(spk_id, b, 1/4, pos, width, closed) +
  node_gain(spk_id, c, 2/4, pos, width, closed) +
  node_gain(spk_id, d, 3/4, pos, width, closed);
);

function path4_open_gain(spk_id, pos, width, a, b, c, d)
(
  node_gain(spk_id, a, 0/3, pos, width, 0) +
  node_gain(spk_id, b, 1/3, pos, width, 0) +
  node_gain(spk_id, c, 2/3, pos, width, 0) +
  node_gain(spk_id, d, 3/3, pos, width, 0);
);

function path5_gain(spk_id, pos, width, closed, a, b, c, d, e)
(
  node_gain(spk_id, a, 0/5, pos, width, closed) +
  node_gain(spk_id, b, 1/5, pos, width, closed) +
  node_gain(spk_id, c, 2/5, pos, width, closed) +
  node_gain(spk_id, d, 3/5, pos, width, closed) +
  node_gain(spk_id, e, 4/5, pos, width, closed);
);

function path7_gain(spk_id, pos, width, closed, a, b, c, d, e, f, h)
(
